{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id mod_id, u.username, u.id uid\n        FROM mods m\n        INNER JOIN team_members tm ON tm.is_owner = TRUE and tm.team_id = m.team_id\n        INNER JOIN users u ON u.id = tm.user_id\n        WHERE m.id = ANY($1)\n        ",
