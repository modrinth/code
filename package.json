{
  "name": "@icarus/monorepo",
  "version": "0.0.0",
  "private": true,
  "author": "fraa2a",
  "scripts": {
    "web:dev": "turbo run dev --filter=@icarus/frontend",
    "web:build": "turbo run build --filter=@icarus/frontend",
    "app:dev": "turbo run dev --filter=@icarus/app",
    "app:build": "turbo run build --filter=@icarus/app",
    "docs:dev": "turbo run dev --filter=@icarus/docs",
    "pages:build": "NITRO_PRESET=cloudflare-pages pnpm --filter frontend run build",
    "build": "turbo run build --continue",
    "lint": "turbo run lint lint:ancillary --continue",
    "lint:ancillary": "prettier --check .github *.*",
    "test": "turbo run test --continue",
    "fix": "turbo run fix fix:ancillary --continue",
    "fix:ancillary": "prettier --write .github *.*",
    "ci": "turbo run lint test --continue",
    "prepr": "turbo run prepr --continue",
    "prepr:frontend": "turbo run prepr --filter=@icarus/frontend --filter=@icarus/app-frontend",
    "prepr:frontend:lib": "turbo run prepr --filter=@icarus/ui --filter=@icarus/moderation --filter=@icarus/assets --filter=@icarus/blog --filter=@icarus/api-client --filter=@icarus/utils --filter=@icarus/tooling-config",
    "prepr:frontend:web": "turbo run prepr --filter=@icarus/frontend",
    "prepr:frontend:app": "turbo run prepr --filter=@icarus/app-frontend",
    "storybook": "pnpm --filter @icarus/ui storybook",
    "build-storybook": "pnpm --filter @icarus/ui build-storybook",
    "icons:add": "pnpm --filter @icarus/assets icons:add",
    "changelog:collect": "node scripts/run.mjs collect-changelog",
    "changelog:combine-for-app": "node scripts/run.mjs build-theseus-release-notes",
    "scripts": "node scripts/run.mjs"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.0",
    "@icarus/tooling-config": "workspace:*",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/node": "^24",
    "@vue/compiler-dom": "^3.5.26",
    "@vue/compiler-sfc": "^3.5.26",
    "chalk": "^5.6.2",
    "if-ci": "^3.0.0",
    "keep-a-changelog": "^3.0.2",
    "prettier": "^3.3.2",
    "turbo": "^2.5.4",
    "vue": "^3.5.13",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.15.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "8",
        "esbuild": "0"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "prettier": "@icarus/tooling-config/prettier.config.cjs",
  "patchedDependencies": {
    "readable-stream@2.3.8": "patches/readable-stream@2.3.8.patch"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
